<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkBox" id="rule_search_chips_editor">
    <property name="orientation">vertical</property>
    <property name="spacing">8</property>
    <child>
      <object class="AdwWrapBox" id="rule_search_chips_wrap">
        <property name="align">0</property>
        <property name="child-spacing">6</property>
        <property name="line-spacing">6</property>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <child>
          <object class="AdwEntryRow" id="rule_search_chips_entry">
            <property name="title" translatable="yes">Add search text</property>
            <property name="show-apply-button">False</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
