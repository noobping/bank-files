<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.6"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkBox" id="partial_load_notice_card">
    <property name="orientation">vertical</property>
    <property name="hexpand">True</property>
    <property name="margin-top">4</property>
    <property name="margin-bottom">4</property>
    <property name="margin-start">4</property>
    <property name="margin-end">4</property>
    <style>
      <class name="card"/>
    </style>
    <child>
      <object class="GtkBox" id="partial_load_notice_content">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkImage" id="partial_load_notice_icon">
            <property name="icon-name">dialog-information-symbolic</property>
            <property name="pixel-size">28</property>
            <property name="valign">start</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="partial_load_notice_text_box">
            <property name="orientation">vertical</property>
            <property name="spacing">4</property>
            <property name="hexpand">True</property>
            <child>
              <object class="GtkLabel" id="partial_load_notice_title">
                <property name="label" translatable="yes">Only part of the CSV records is loaded</property>
                <property name="xalign">0</property>
                <property name="width-chars">1</property>
                <property name="wrap">True</property>
                <property name="wrap-mode">word-char</property>
                <style>
                  <class name="title-4"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="partial_load_notice_message">
                <property name="selectable">True</property>
                <property name="xalign">0</property>
                <property name="width-chars">1</property>
                <property name="max-width-chars">78</property>
                <property name="wrap">True</property>
                <property name="wrap-mode">word-char</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="partial_load_notice_reload_button">
            <property name="valign">start</property>
            <property name="tooltip-text" translatable="yes">Force reload all CSV files</property>
            <property name="child">
              <object class="AdwButtonContent" id="partial_load_notice_reload_content">
                <property name="icon-name">view-refresh-symbolic</property>
                <property name="label" translatable="yes">Reload All</property>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
