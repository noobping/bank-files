<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.6"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkBox" id="operation_queue_content">
    <property name="orientation">vertical</property>
    <property name="spacing">18</property>
    <property name="margin-top">18</property>
    <property name="margin-bottom">18</property>
    <property name="margin-start">18</property>
    <property name="margin-end">18</property>
    <child>
      <object class="GtkBox" id="operation_queue_summary_row">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>
        <property name="hexpand">True</property>
        <child>
          <object class="GtkLabel" id="operation_queue_summary">
            <property name="hexpand">True</property>
            <property name="selectable">False</property>
            <property name="xalign">0</property>
            <property name="width-chars">1</property>
            <property name="wrap">True</property>
            <property name="wrap-mode">word-char</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="operation_queue_clear_done_button">
            <property name="icon-name">edit-clear-symbolic</property>
            <property name="tooltip-text" translatable="yes">Clear completed operations</property>
            <style>
              <class name="flat"/>
              <class name="image-button"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkListBox" id="operation_queue_list">
        <property name="selection-mode">none</property>
        <property name="hexpand">True</property>
        <style>
          <class name="boxed-list"/>
        </style>
      </object>
    </child>
  </object>
</interface>
