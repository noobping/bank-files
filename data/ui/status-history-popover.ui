<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.6"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkBox" id="status_history_title_header">
    <property name="orientation">horizontal</property>
    <property name="spacing">8</property>
    <property name="hexpand">True</property>
    <child>
      <object class="GtkBox" id="status_history_title_box">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <property name="hexpand">True</property>
        <child>
          <object class="GtkLabel" id="status_history_title">
            <property name="xalign">0</property>
            <property name="width-chars">1</property>
            <property name="max-width-chars">28</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="status_history_subtitle">
            <property name="xalign">0</property>
            <property name="width-chars">1</property>
            <property name="max-width-chars">34</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="status_history_title_actions">
        <property name="orientation">horizontal</property>
        <property name="spacing">0</property>
        <style>
          <class name="linked"/>
        </style>
        <child>
          <object class="GtkButton" id="status_history_search_button">
            <property name="icon-name">edit-find-symbolic</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="status_history_copy_button">
            <property name="icon-name">edit-copy-symbolic</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="status_history_save_button">
            <property name="icon-name">document-save-symbolic</property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="status_history_search_header">
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>
    <property name="hexpand">True</property>
    <style>
      <class name="linked"/>
    </style>
    <child>
      <object class="GtkButton" id="status_history_back_button">
        <property name="icon-name">go-previous-symbolic</property>
      </object>
    </child>
    <child>
      <object class="GtkSearchEntry" id="status_history_search_entry">
        <property name="hexpand">True</property>
      </object>
    </child>
  </object>
</interface>
